{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SA-2025 Generator",
  "version": "0.1.0",
  "identifier": "com.sa2025.generator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SA-2025 Generator",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["saproj"],
        "name": "SA-2025 Project",
        "description": "SA-2025 Project File",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/MatDowall/SA-2025-Generator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY2MzBFM0VFMUFGMEExNkEKUldScW9mQWE3dU13OWo4UFp4YllhbVFuaU45aGs2dC9IVCsyeDFkTm4zdUtDekZ5c1NKQzhjSjEK"
    }
  }
}
